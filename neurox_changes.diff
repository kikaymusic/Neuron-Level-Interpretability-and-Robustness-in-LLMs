-                list(range(self.probs.shape[0])), labels
-            ].mean()
-        mutual_inf = (entropy - conditional_entropy) / torch.tensor(2.0).log()
-        return preds, labels, accuracy, mutual_inf.item(), (mutual_inf / entropy).item()
