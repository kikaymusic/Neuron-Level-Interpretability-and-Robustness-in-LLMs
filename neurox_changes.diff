-            log_probs = []
-            for i in range(self.labels_dim):
-                if self.train_categorical[i] == 0:
-                    log_probs.append(torch.zeros(features.shape[0], dtype=torch.double))
-                else:
-                    log_probs.append(
-                        self.distributions[i].log_prob(features[:, selected_features])
